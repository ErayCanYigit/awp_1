  {
    "model": "core.generalsetting",
    "pk": 7,
    "fields": {
      "name": "about_myself_welcome",
      "description": "About section main text",
      "parameter": "Piri Reis Üniversitesi'nde 3. sınıf Bilişim Sistemleri Mühendisliği öğrencisiyim. Yazılım geliştirme, bulut bilişim ve siber güvenlik alanlarına ilgi duyuyor, bu konularda kendimi sürekli geliştirmeye çalışıyorum. MSK Global Elektronik'te edindiğim network yönetimi, firewall konfigürasyonları ve veri merkezi kurulum deneyimlerinin ardından, LimonCloud bünyesinde DevOps ve AWS odaklı projelerde aktif rol aldım. Gerçek projelerde görev alarak altyapı tasarımı, servis yönetimi ve ekip çalışması gibi beceriler kazandım. Sonrasında İstanbul Valiliği Bilgi İşlem Şube Müdürlüğü'nde web uygulama geliştirme, SQL entegrasyonu ve Palo Alto güvenlik duvarı üzerinde yapılandırmalar gerçekleştirdim.",
      "updated_date": "2026-05-17T17:00:00Z",
      "created_date": "2026-05-17T17:00:00Z"
    }
  },
  {
    "model": "core.generalsetting",
    "pk": 8,
    "fields": {
      "name": "about_myself_footer",
      "description": "About section footer text",
      "parameter": "C/C++, Python ve JavaScript dilleriyle çalışıyor; AWS, Google Cloud ve Huawei Cloud altyapıları üzerine yetkinliklerimi artırmaya odaklanıyorum. Amacım, teknolojiyle değer üreten, çözüm odaklı ve gelişime açık bir mühendis olmak.",
      "updated_date": "2026-05-17T17:00:00Z",
      "created_date": "2026-05-17T17:00:00Z"
    }
